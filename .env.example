# OpenCrypto Framework — Environment Configuration
# Copy this file to .env and fill in your values.

# Telegram Bot (optional — for signal notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Groq AI (optional — for AI-powered trade commentary)
GROQ_API_KEY=

# LLM toggle (set to false to disable AI features)
USE_LLM=true
